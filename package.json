{
  "name": "front-oms-app",
  "version": "0.1.0",
  "description": "App móvil iOS (App Store) Mimbral 360 — OMS",
  "author": "Mimbral",
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --cache",
    "typecheck": "tsc --noEmit --pretty false",
    "format:check": "prettier --check .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "for /f %p in ('tasklist ^| findstr electron.exe') do taskkill /f /im %p & npm run build && electron-builder",
    "dev:test": "next dev -p 3001",
    "build:app": "next build",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync ios",
    "cap:copy": "cap copy ios",
    "cap:open": "cap open ios",
    "ios": "npm run build:app && cap sync ios && cap open ios"
  },
  "build": {
    "extends": null,
    "asar": true,
    "asarUnpack": [
      "next.config.js"
    ],
    "files": [
      "electron.js",
      "preload.js",
      "next.config.js",
      ".next/**/*",
      "public/**/*"
    ],
    "extraMetadata": {
      "main": "electron.js"
    },
    "directories": {
      "buildResources": "assets"
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/handlebars": "^4.0.40",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.179.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^5.3.0",
    "electron": "^28.3.3",
    "electron-builder": "^23.6.0",
    "electron-is-dev": "^1.2.0",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.1.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^4.9.5",
    "wait-on": "^5.2.0"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-json": "^6.0.2",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^6.1.2",
    "@mui/lab": "^6.0.0-beta.10",
    "@mui/material": "^6.1.2",
    "@mui/x-date-pickers": "^8.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@react-google-maps/api": "^2.20.7",
    "@tanstack/react-table": "^8.21.2",
    "@types/js-cookie": "^3.0.6",
    "@uiw/codemirror-theme-dracula": "^4.25.2",
    "@uiw/react-codemirror": "^4.25.2",
    "chart.js": "^4.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "electron-is-dev": "^1.2.0",
    "handlebars": "^4.7.8",
    "js-cookie": "^3.0.5",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.473.0",
    "next": "^15.1.4",
    "next-themes": "^0.4.4",
    "prettier": "^3.6.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.4.0",
    "react-router-dom": "^6.26.2",
    "react-scripts": "^0.0.0",
    "react-select": "^5.10.2",
    "recharts": "^3.7.0",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "three": "^0.179.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
