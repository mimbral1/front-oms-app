# Variables de entorno — front-oms-app (iOS / App Store)
#
# IMPORTANTE: al ser un static export (output: "export"), todas las NEXT_PUBLIC_*
# se incrustan en BUILD TIME. Cualquier cambio requiere reconstruir:
#   npm run build:app && npx cap sync ios
#
# App Store exige HTTPS (ATS). Evita http:// e IPs de LAN en producción.

# --- Gateway / API principal ---
NEXT_PUBLIC_URL_BASE=
NEXT_PUBLIC_URL_BASE_QA=
NEXT_PUBLIC_OMS_BASE_URL=
NEXT_PUBLIC_URL_BACKOMS=

# --- Almacén / Inventario ---
NEXT_PUBLIC_URL_BASE_WAREHOUSES=
NEXT_PUBLIC_BASE_INVENTORY_DOCS_API=
NEXT_PUBLIC_BASE_MOVEMENTS_API=

# --- Delivery / TMS ---
NEXT_PUBLIC_BASE_URL_DELIVERY_SERVICE=
NEXT_PUBLIC_BASE_URL_TMS_SERVICE=
NEXT_PUBLIC_BASE_URL_HOLIDAY_SERVICE=
NEXT_PUBLIC_ROUTE_INTEGRATION_ID=

# --- Catálogo / PIM / Pricing ---
NEXT_PUBLIC_URL_PIM_SERVICE=
NEXT_PUBLIC_URL_MIMBRAL_MAPEOS=
NEXT_PUBLIC_PRICING_IP_BASE=
NEXT_PUBLIC_BASE_ANALYSIS_SERVICE=
NEXT_PUBLIC_BASE_ANALYSIS_SERVICE_CATALOGO=
NEXT_PUBLIC_COMMERCE_SERVICE_LOCATIONS_SIMPLE=

# --- Janis (credenciales) ---
NEXT_PUBLIC_JANIS_API_KEY=
NEXT_PUBLIC_JANIS_API_SECRET=
NEXT_PUBLIC_JANIS_CLIENT=

# --- Google Maps (delivery) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# --- Otros / internos ---
NEXT_PUBLIC_URL_BASE_168_5008=
NEXT_PUBLIC_URL_BASE_26_5005=
NEXT_PUBLIC_URL_BASE_92_5005=
NEXT_PUBLIC_RERUN_PWD=
